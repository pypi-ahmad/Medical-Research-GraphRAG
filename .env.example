# Copy this to .env and set values.
# Required for Pinecone notebook section (NB03_Pinecone_GraphRAG).
PINECONE_API_KEY=
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_INDEX_PREFIX=medmentions-graphrag

# Optional: override Ollama endpoint if not using local default.
OLLAMA_HOST=http://127.0.0.1:11434

# Additive notebook/model settings for NB06+.
JUDGE_MODEL=granite4.1:8b
# Backward-compatible alias used by legacy additive code paths.
GUARDIAN_JUDGE_MODEL=granite4.1:8b
MULTIMODAL_OCR_MODEL=glm-ocr
MULTIMODAL_VISION_MODEL=qwen3.5:4b
OCR_CLI_ALLOW_FALLBACK=true
OCR_CLI_TIMEOUT_SECONDS=120

# Optional NB11 fine-tuning track (Unsloth + PEFT + TRL).
# Keep disabled unless you explicitly run the selective fine-tuning notebook.
FINETUNE_BASE_MODEL_HF=unsloth/llama-3.2-3b-instruct
FINETUNE_ADAPTER_NAME=medresearch-lora
FINETUNE_MAX_TRAIN_EXAMPLES=2500
FINETUNE_MAX_EVAL_EXAMPLES=300
FINETUNE_MAX_SEQ_LENGTH=2048
FINETUNE_LORA_RANK=16
FINETUNE_LORA_ALPHA=32
FINETUNE_LORA_DROPOUT=0.0
FINETUNE_TRAIN_BATCH_SIZE=2
FINETUNE_GRAD_ACCUMULATION=8
FINETUNE_LEARNING_RATE=0.0002
FINETUNE_MAX_STEPS=120
FINETUNE_WARMUP_STEPS=10
FINETUNE_EXPORT_GGUF=false
